# Application
APP_NAME=MessengerAPI
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://messenger_user:messenger_pass@localhost:5432/messenger_db
SYNC_DATABASE_URL=postgresql://messenger_user:messenger_pass@localhost:5432/messenger_db

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OTP Settings
OTP_EXPIRE_MINUTES=5
OTP_DEV_MODE=true

# Media Storage
MEDIA_STORAGE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# AWS S3 (optional, when MEDIA_STORAGE=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=messenger-media

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SECRET_KEY=admin-secret-key-change-in-production


BASE_URL=http://localhost:8000